models/
data/
results/
__pycache__/
*.pyc
.env
.env.local
.env.bwuni
.env.dws
wandb/
*.out
oaei_track_cache/

# IDE state
.idea/
.claude/

# BeyondEquivalence raw data — too large for git, official source is Zenodo
# (DOI 10.5281/zenodo.17091043). The loader expects benchmark.zip in the project
# root (or override via ZENODO_BENCHMARK_ZIP); on a fresh clone download it once
# from Zenodo.
benchmark.zip
results/
logs/

# W&B fallback paths — current wandb writes everything under wandb/run-*/, but
# older versions / offline-then-sync flows occasionally drop files in cwd.
.wandb/
wandb-debug.log
wandb-debug-internal.log
wandb-metadata.json
wandb-summary.json

# Hugging Face Hub / filelock library may drop *.lock files in cwd if the
# HF_HOME / cache redirection isn't picked up by every code path on the cluster.
*.lock

# Test runner cache — only created if pytest is run from a compute node.
.pytest_cache/
