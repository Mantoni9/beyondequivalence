MODEL_PATH=$WORK/models/Llama-3.3-70B-Instruct
DEVICE=cuda
CLUSTER=bwuni

# vLLM server settings — used by jobs/job_bwuni_vllm.sh
# VLLM_BASE_URL is set dynamically by the job script (not here).
# No quantization on bwUniCluster: 2× A100 80GB = 160 GB total,
# LLaMA 3.3 70B in BF16 fits with tensor-parallel-size 2.
VLLM_TENSOR_PARALLEL=2
VLLM_MAX_MODEL_LEN=8192
